rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Platform-level super admin check (reads /users/{uid}.platformRole)
    function isSuperAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.platformRole == 'super_admin';
    }

    // Org membership check
    function isMember(orgId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function memberRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function hasRole(orgId, roles) {
      return isMember(orgId) && memberRole(orgId) in roles;
    }

    // Org status check — only approved orgs allow writes
    function isOrgApproved(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.status == 'approved';
    }

    // Combined: member of an approved org
    function canAccess(orgId) {
      return isMember(orgId) && isOrgApproved(orgId);
    }

    // Role shortcuts
    function isOwner(orgId) {
      return hasRole(orgId, ['owner']);
    }

    function isAdminOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin']);
    }

    function isAccountantOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'accountant']);
    }

    function isClerkOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'accountant', 'clerk']);
    }

    // ============================================================
    // USERS — each user can only read/write their own doc
    // Super admins can read all users
    // ============================================================
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      // platformRole field is protected: only super admins can set it
      // (enforced by: regular users can update their own doc but the
      //  frontend never writes platformRole — backend-only field)
    }

    // ============================================================
    // INVITATIONS — root-level collection
    // ============================================================
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn() && isAdminOrAbove(request.resource.data.orgId);
      allow update: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
      allow delete: if isSignedIn() && (
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
    }

    // ============================================================
    // ORGANIZATIONS
    // ============================================================
    match /organizations/{orgId} {
      // Any member can read their org; super admins can read all
      allow read: if isMember(orgId) || isSuperAdmin();

      // Anyone signed in can create (status will be 'pending')
      allow create: if isSignedIn();

      // Owner can update their org; super admins can update any (for approval)
      allow update: if isOwner(orgId) || isSuperAdmin();

      // Only super admins can delete orgs
      allow delete: if isSuperAdmin();

      // ---- Members ----
      match /members/{memberId} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow create: if isSignedIn() && (
          request.auth.uid == memberId ||
          isAdminOrAbove(orgId) ||
          isSuperAdmin()
        );
        allow update: if isAdminOrAbove(orgId) || isSuperAdmin();
        allow delete: if isAdminOrAbove(orgId) || request.auth.uid == memberId || isSuperAdmin();
      }

      // ---- Settings ----
      match /settings/{settingId} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isOwner(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Chart of Accounts ----
      match /accounts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Journal Entries ----
      match /journalEntries/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Customers ----
      match /customers/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Sales Invoices ----
      match /salesInvoices/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Quotes ----
      match /quotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Credit Notes ----
      match /creditNotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Receipts ----
      match /receipts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Suppliers ----
      match /suppliers/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Purchase Invoices (Bills) ----
      match /purchaseInvoices/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Purchase Orders ----
      match /purchaseOrders/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Debit Notes ----
      match /debitNotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Payments ----
      match /payments/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Bank Accounts ----
      match /bankAccounts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Bank Transactions ----
      match /bankTransactions/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ---- Reconciliations ----
      match /reconciliations/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }
    }
  }
}
