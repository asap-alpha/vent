rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Platform-level super admin (reads /users/{uid}.platformRole).
    // Defaults to false if the field is missing.
    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('platformRole', 'user') == 'super_admin';
    }

    // Org membership — user has a member doc at /organizations/{orgId}/members/{uid}
    function isMember(orgId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function memberRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    function hasRole(orgId, roles) {
      return isMember(orgId) && memberRole(orgId) in roles;
    }

    // Org status check — defaults to 'approved' for legacy orgs without status field
    function isOrgApproved(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.get('status', 'approved') == 'approved';
    }

    // Role shortcuts
    function isOwner(orgId) {
      return hasRole(orgId, ['owner']);
    }

    function isAdminOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin']);
    }

    function isAccountantOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'accountant']);
    }

    function isClerkOrAbove(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'accountant', 'clerk']);
    }

    // The user who created the org (used to authorize the creator's owner member doc).
    function isOrgCreator(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy == request.auth.uid;
    }

    // A self-service member add is only legitimate when it matches a real pending
    // invitation for THIS org and the SAME role. The member doc must carry the
    // invitationId. Invitation ids are random/secret (delivered by email), so this
    // closes the "write yourself in as owner" hole.
    function hasMatchingInvite(orgId) {
      let invId = request.resource.data.get('invitationId', '');
      return invId != '' &&
        exists(/databases/$(database)/documents/invitations/$(invId)) &&
        get(/databases/$(database)/documents/invitations/$(invId)).data.orgId == orgId &&
        get(/databases/$(database)/documents/invitations/$(invId)).data.role == request.resource.data.role &&
        get(/databases/$(database)/documents/invitations/$(invId)).data.status == 'pending';
    }

    // Owners may edit only business fields, and may cancel their own subscription.
    // Approval (`status`), plan, trial and billing-period fields are platform-managed
    // (super admin, or the payment backend via the Admin SDK which bypasses rules) so
    // an owner can't self-approve their org or grant themselves a plan/trial.
    function ownerOrgEdit(orgId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(orgId) &&
        changed.hasOnly(['name', 'currency', 'fiscalYearStart', 'subscriptionStatus', 'canceledAt']) &&
        (!changed.hasAny(['subscriptionStatus']) || request.resource.data.subscriptionStatus == 'canceled');
    }

    // ============================================================
    // USERS
    // - Users can read/write their own profile doc
    // - Super admins can read/write any profile (used to set platformRole, list users)
    // ============================================================
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // INVITATIONS (root-level collection)
    // - Invited user (by email match) can read + update their own invitation
    // - Org admins/owners can create, read, update, delete invitations for their org
    // - Super admins can do anything
    // ============================================================
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn() && (
        isAdminOrAbove(request.resource.data.orgId) ||
        isSuperAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
      allow delete: if isSignedIn() && (
        isAdminOrAbove(resource.data.orgId) ||
        isSuperAdmin()
      );
    }

    // ============================================================
    // DISCOUNTS (root-level collection)
    // - Super admins manage (create/list/revoke) per-org subscription codes.
    // - No one else reads them: codes are shared out of band and validated
    //   server-side (Cheqam backend via the Vent Admin SDK, which bypasses rules),
    //   and the backend also flips them to `used` after payment.
    // ============================================================
    match /discounts/{discountId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // ORGANIZATIONS
    // ============================================================
    match /organizations/{orgId} {
      // Members can read their org; super admins can read all
      allow read: if isMember(orgId) || isSuperAdmin();

      // Any signed-in user can create (it'll be in 'pending' status)
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;

      // Super admins can update any org (approval, plan, trial). Owners are limited
      // to business fields + cancelling their own subscription — see ownerOrgEdit.
      allow update: if isSuperAdmin() || ownerOrgEdit(orgId);

      // Only super admins can delete an org
      allow delete: if isSuperAdmin();

      // ============================================
      // Members subcollection
      // ============================================
      match /members/{memberId} {
        allow read: if isMember(orgId) || isSuperAdmin();
        // Who may create a member doc:
        //  • super admin — anyone;
        //  • an admin/owner — anyone EXCEPT a new owner (no minting owners);
        //  • the org creator — their own owner doc at creation time;
        //  • an invited user — their own doc, matching a pending invitation (role-locked).
        allow create: if isSuperAdmin() ||
          (isAdminOrAbove(orgId) && request.resource.data.role != 'owner') ||
          (request.auth.uid == memberId && isOrgCreator(orgId)) ||
          (request.auth.uid == memberId && hasMatchingInvite(orgId));
        // Admins can change roles, but can't touch the owner or promote anyone to owner.
        allow update: if isSuperAdmin() ||
          (isAdminOrAbove(orgId) && resource.data.role != 'owner' && request.resource.data.role != 'owner');
        // Admins can remove members, users can remove themselves — but the owner can
        // only be removed by a super admin (prevents orphaning / hostile removal).
        allow delete: if isSuperAdmin() ||
          ((isAdminOrAbove(orgId) || request.auth.uid == memberId) && resource.data.role != 'owner');
      }

      // ============================================
      // Settings subcollection — owner-only
      // ============================================
      match /settings/{settingId} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isOwner(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ============================================
      // Accounting (Accountant+ can write)
      // ============================================
      match /accounts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /journalEntries/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ============================================
      // Sales (Clerk+ can write)
      // ============================================
      match /customers/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /salesInvoices/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /quotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /creditNotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /receipts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ============================================
      // Purchases (Clerk+ can write)
      // ============================================
      match /suppliers/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /purchaseInvoices/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /purchaseOrders/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /debitNotes/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /payments/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isClerkOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      // ============================================
      // Banking (Accountant+ can write)
      // ============================================
      match /bankAccounts/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /bankTransactions/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }

      match /reconciliations/{document=**} {
        allow read: if isMember(orgId) || isSuperAdmin();
        allow write: if (isAccountantOrAbove(orgId) && isOrgApproved(orgId)) || isSuperAdmin();
      }
    }
  }
}
